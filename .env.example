# Copie para .env e preencha.  ->  cp .env.example .env

# --- Caixa de email (IMAP) — conta Hotmail/Outlook ---
IMAP_HOST=outlook.office365.com
IMAP_PORT=993
IMAP_USER=lis-ls@hotmail.com
IMAP_MAILBOX=INBOX
FETCH_LIMIT=150

# Só ingere emails cujo remetente contenha este texto. Vazio = todos.
MONDAY_SENDER=monday.com

# --- OAuth2 Microsoft (obrigatório para Hotmail/Outlook) ---
# Senha simples NÃO funciona mais nessas contas. Crie um registro de app no
# Azure/Entra (veja o README) e cole aqui o "ID do aplicativo (cliente)".
MS_CLIENT_ID=
# Conta pessoal (hotmail) -> consumers. Conta corporativa -> .../common
MS_AUTHORITY=https://login.microsoftonline.com/consumers

# --- PostgreSQL ---
POSTGRES_DB=solicitacoes
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Fora do Docker, aponte para seu Postgres:
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/solicitacoes
