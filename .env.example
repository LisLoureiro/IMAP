# Copie para .env e preencha.  ->  cp .env.example .env

# --- Caixa de email (IMAP) — conta corporativa VERT ---
IMAP_HOST=outlook.office365.com
IMAP_PORT=993
IMAP_USER=lis.sousa@vert-capital.com
IMAP_MAILBOX=INBOX
FETCH_LIMIT=150

# Filtra notificações por remetente. Vazio = ingere todos os emails.
# Na VERT as notificações chegam de crm@vert-capital.com — deixe vazio
# para não bloquear, ou use "vert-capital.com" para filtrar pela empresa.
MONDAY_SENDER=

# --- OAuth2 Microsoft 365 (obrigatório para conta corporativa) ---
# Senha simples NÃO funciona. Crie um registro de app no Azure/Entra
# (veja o README) e cole aqui o "ID do aplicativo (cliente)".
MS_CLIENT_ID=
# Conta corporativa: use "common" ou o tenant ID específico da VERT
MS_AUTHORITY=https://login.microsoftonline.com/common

# --- PostgreSQL ---
POSTGRES_DB=solicitacoes
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Fora do Docker, aponte para seu Postgres:
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/solicitacoes
